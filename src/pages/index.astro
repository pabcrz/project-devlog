---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const allEntries = await getCollection("entries");
const sorted = allEntries.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
const allTopics = [...new Set(allEntries.flatMap((e) => e.data.topics))].sort();

const topicEntries = (topic: string) =>
  sorted.filter((e) => e.data.topics.includes(topic));

const phases = [
  { key: "origen", label: "Origen", range: "Feb – Abr 2026", desc: "Idea, dominio y el reset que ordenó todo." },
  { key: "aprendizaje", label: "Aprendizaje", range: "May 2026", desc: "TypeScript, modelado y los patrones que después usé en todo." },
  { key: "reconstruccion", label: "Reconstrucción", range: "Jun 2026", desc: "Desde cero: schema, auth, features. Sin deuda." },
  { key: "produccion", label: "Producción", range: "Jun 2026", desc: "Deploy, debugging real, PWA y flujo de trabajo con PRs." },
  { key: "reflexiones", label: "Reflexiones", range: "Jun 2026", desc: "Lo que quedó después de construir: patrones que funcionan." },
] as const;

const phaseEntries = (key: string) => {
  const entries = sorted.filter((e) => e.data.phase === key);
  const featured = entries.filter((e) => e.data.featured);
  const rest = entries.filter((e) => !e.data.featured);
  return [...featured, ...rest];
};
---

<BaseLayout
  title="project-devlog"
  description="Registro de decisiones técnicas, arquitectura y aprendizajes durante el desarrollo de una app operativa."
>
  <p class="text-sm sm:text-base text-text-muted leading-relaxed max-w-2xl mb-6">
    Registro de decisiones técnicas, problemas resueltos y arquitectura de una app operativa real.
    Sin marketing, sin hype.
  </p>

  <div class="flex flex-wrap gap-1.5 mb-10">
    {allTopics.map((topic) => (
      <a href={`#topic-${topic.toLowerCase()}`} class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-medium bg-navy-50 text-navy-600 border border-navy-100 hover:border-navy-300 hover:text-navy-800 transition-colors no-underline">
        {topic}
      </a>
    ))}
  </div>

  <div class="space-y-10">
    {phases.map((phase) => {
      const entries = phaseEntries(phase.key);
      if (entries.length === 0) return null;
      return (
        <section>
          <div class="mb-3">
            <h2 class="text-base font-bold tracking-tight text-text-main">
              {phase.label}
            </h2>
            <div class="flex items-center gap-2 mt-0.5">
              <span class="text-[11px] text-text-muted font-mono">{phase.range}</span>
              <span class="text-[11px] text-text-muted">{phase.desc}</span>
            </div>
          </div>

          <div class="space-y-2">
            {entries.map((entry) => (
              <a href={`/entries/${entry.id}`} class="block group bg-surface border border-border-light rounded-lg px-4 sm:px-5 py-3.5 shadow-sm hover:shadow-md hover:border-navy-200 transition-colors no-underline">
                <div class="flex items-center gap-2.5 mb-1">
                  <time class="text-[11px] text-text-muted font-mono tabular-nums">
                    {entry.data.date.toLocaleDateString("es-MX", { year: "numeric", month: "short", day: "numeric" })}
                  </time>
                  <span class={`inline-flex items-center px-1.5 py-px rounded-full text-[10px] font-semibold uppercase tracking-wide ${entry.data.type === "case-study" ? "bg-navy-700 text-white" : "bg-navy-50 text-navy-600 border border-navy-100"}`}>
                    {entry.data.type === "case-study" ? "case study" : "log"}
                  </span>
                  {entry.data.featured && <span class="text-[10px] text-amber-500 leading-none">★</span>}
                </div>
                <h3 class="text-sm font-semibold text-text-main group-hover:text-primary transition-colors">
                  {entry.data.title}
                </h3>
              </a>
            ))}
          </div>
        </section>
      );
    })}
  </div>

  <!-- Topic anchors -->
  {allTopics.map((topic) => (
    <section id={`topic-${topic.toLowerCase()}`} class="mt-10 pt-6 border-t border-border-light">
      <h2 class="text-sm font-semibold text-text-main mb-3">Entradas sobre <span class="text-primary">{topic}</span></h2>
      <div class="space-y-2">
        {topicEntries(topic).map((entry) => (
          <a href={`/entries/${entry.id}`} class="block group bg-surface border border-border-light rounded-lg px-4 py-3 shadow-sm hover:border-navy-200 transition-colors no-underline">
            <div class="flex items-center gap-2.5 mb-0.5">
              <time class="text-[11px] text-text-muted font-mono">
                {entry.data.date.toLocaleDateString("es-MX", { year: "numeric", month: "short", day: "numeric" })}
              </time>
              <span class="text-[11px] text-text-muted">{entry.data.phase}</span>
            </div>
            <h3 class="text-sm font-medium text-text-main group-hover:text-primary transition-colors">
              {entry.data.title}
            </h3>
          </a>
        ))}
      </div>
    </section>
  ))}
</BaseLayout>
